{
  "$schema": "workspace-spec/1.0.0",
  "version": "1.4.0",
  "description": "工作区骨架规格 — 单一事实源（SSOT）。framework-check.ps1、normalize.ps1、init_workspace.py 均从此文件读取标准。",

  "rootDirectories": [
    ".agents",
    ".history",
    ".memory",
    ".system",
    ".temp",
    "input",
    "output"
  ],

  "overwriteLayer": {
    "description": "覆盖层：exe 每次运行都强制替换（旧版先备份到 .history）",
    "rules": [
      "direction-rules.md",
      "filename-rules.md",
      "memory-rules.md",
      "version-control-rules.md"
    ],
    "skills": [
      "创建技能",
      "子项目管理",
      "安装技能",
      "框架体检",
      "版本控制备份",
      "记忆管理",
      "项目规范化",
      "课题研究"
    ],
    "standards": [
      "workspace-spec.json",
      "工作区骨架规格.md",
      "工作区命名规范.md"
    ]
  },

  "requiredLayer": {
    "description": "必备层：exe 补缺，已有则跳过",

    "directories": [
      ".agents/rules",
      ".agents/skills",
      ".history/output",
      ".history/.agents/rules",
      ".history/.agents/skills",
      ".history/.memory/对话记录",
      ".history/.memory/知识提炼",
      ".history/.memory/系统记录",
      ".history/.memory/全局知识地图",
      ".history/.system",
      ".history/.system/standards",
      ".memory/对话记录",
      ".memory/知识提炼",
      ".memory/系统记录",
      ".system/standards",
      ".temp",
      "input",
      "output"
    ],

    "files": {
      ".system/standards/workspace-spec.json": {
        "description": "工作区机器可读 SSOT",
        "createIfMissing": true
      },
      ".system/standards/工作区骨架规格.md": {
        "description": "工作区骨架人类可读标准",
        "createIfMissing": true
      },
      ".system/standards/工作区命名规范.md": {
        "description": "工作区命名人类可读标准",
        "createIfMissing": true
      },
      ".memory/全局知识地图.md": {
        "description": "全局索引",
        "createIfMissing": true
      },
      ".memory/系统记录/规则变更记录.md": {
        "description": "Rule 增删改历史",
        "createIfMissing": true
      },
      ".memory/系统记录/技能变更记录.md": {
        "description": "Skill 增删改历史",
        "createIfMissing": true
      },
      ".memory/系统记录/脚本治理记录.md": {
        "description": "脚本 bug/编码/编译/封装",
        "createIfMissing": true
      },
      ".memory/系统记录/教训库.md": {
        "description": "跨领域教训/根因/纠偏",
        "createIfMissing": true
      },
      ".memory/系统记录/索引.md": {
        "description": "系统记录索引入口",
        "createIfMissing": true
      }
    },

    "coreSubproject": {
      "name": "系统治理",
      "initialVersion": "1.0.0",
      "description": "核心骨架子项目，必须存在",
      "subfolders": [
        "01_问题答疑_v0.0.0",
        "02_课题研究_v0.0.0",
        "03_代码程序_v0.0.0"
      ],
      "fixedFiles": ["目录.md", "版本记录.md"],
      "conversationRecord": ".memory/对话记录/00_系统治理_v{version}.md",
      "knowledgeDistill": {
        "description": "至少 1 个初始知识提炼文件",
        "minCount": 1
      }
    },

    "systemCore": {
      "root": ".system",
      "description": ".system 是工作区核心骨架；从文件夹到内部所有文件均为必备核心项，不属于可变层。",
      "mutable": false,
      "directories": [
        ".system/standards"
      ],
      "files": [
        ".system/standards/workspace-spec.json",
        ".system/standards/工作区骨架规格.md",
        ".system/standards/工作区命名规范.md"
      ],
      "historyMirrorDirectories": [
        ".history/.system",
        ".history/.system/standards"
      ],
      "backup": {
        "mode": "FOLDER",
        "description": "与 .agents/skills/ 相同：按 .system 内部子文件夹做整文件夹快照，live 文件夹保持原名不变。",
        "historySnapshot": ".history/.system/{.system子文件夹名}_{yyyyMMddHHmmss}/"
      }
    }
  },

  "variableLayer": {
    "description": "可变层：exe 不接触，用户/AI 按需创建",
    "paths": [
      "output/01_*  ~  output/NN_*",
      ".memory/对话记录/01_*.md  ~",
      ".history/output/*/",
      ".history/.system/*_{yyyyMMddHHmmss}/"
    ]
  },

  "governanceGuards": {
    "description": "系统治理三道防线：研究来源核验、核心骨架授权、对话路由。Rule、Skill、脚本和初始化模板必须向此处收敛。",
    "sourceVerification": {
      "description": "研究类输出的核心资料必须可访问、可验证或可下载，并说明当前权威性依据。",
      "appliesTo": [
        "output/*/02_课题研究_v*/",
        ".agents/skills/课题研究/"
      ],
      "requiredFields": [
        "来源类型",
        "作者/机构",
        "年份/版本",
        "可访问路径",
        "可验证标识",
        "可下载路径",
        "访问日期",
        "当前权威性依据",
        "使用方式"
      ],
      "evidenceLabels": [
        "【第一来源】",
        "【权威研究】",
        "【当前标准】",
        "【合理推导】",
        "【待验证】"
      ],
      "forbiddenAsCoreEvidence": [
        "只有模型记忆、没有可复核路径的资料",
        "无法访问、无法验证、无法下载且没有替代核验路径的资料",
        "不知道当前是否仍有效的旧标准、旧指南、旧论文",
        "未标注来源和推导链的断言"
      ]
    },
    "coreEditAuthorization": {
      "description": "核心骨架修改必须先获得用户明确授权；备份是必要条件，不等于授权。",
      "protectedPaths": [
        ".system/standards/",
        ".agents/rules/",
        ".agents/skills/",
        ".agents/skills/*/scripts/",
        "output/05_工作区初始化工具_*/03_代码程序_*/src/templates/",
        "output/05_工作区初始化工具_*/03_代码程序_*/src/",
        ".memory/全局知识地图.md",
        ".memory/知识提炼/*.md"
      ],
      "allowedWithoutAuthorization": [
        "读取核心文件",
        "分析问题和根因",
        "提出修改方案",
        "列出拟修改文件清单",
        "将方案落盘到 output/00_系统治理",
        "追加 .memory/系统记录"
      ],
      "forbiddenWithoutAuthorization": [
        "修改 Rule、Skill、脚本、标准或 05 初始化模板",
        "顺手修复核心骨架问题",
        "通过脚本、批处理或构建流程间接修改核心骨架"
      ],
      "explicitAuthorizationExamples": [
        "允许修改核心骨架",
        "按这个方案改 Rule 和 Skill",
        "可以动 .agents/skills/课题研究",
        "执行第 1 阶段"
      ],
      "notAuthorizationExamples": [
        "你看看怎么处理",
        "出个方案",
        "应该要改",
        "这个要解决"
      ],
      "preEditChecklist": [
        "列出目标文件和理由",
        "判断备份模式",
        "执行版本控制备份",
        "确认不触碰未列出的核心文件",
        "修改文件",
        "运行最小验证",
        "写入系统记录"
      ]
    },
    "conversationRouting": {
      "description": "所有用户输入先判内容路由 PROJECT / SYSTEM / BOTH，再按任务类型选择 Rule、Skill、输出位置和记忆位置。",
      "contentRoutes": ["PROJECT", "SYSTEM", "BOTH"],
      "taskTypes": [
        "普通知识问答",
        "结构化研究",
        "系统治理方案",
        "Rule/Skill 修改请求",
        "代码实现",
        "规范化/体检",
        "记忆问题",
        "文档/表格/演示文件"
      ],
      "defaultSystemProject": "output/00_系统治理_v*",
      "memoryTargets": {
        "PROJECT": ".memory/对话记录/{子项目文件夹名}.md",
        "SYSTEM": ".memory/系统记录/{分类文件}.md",
        "BOTH": "同时写项目对话记录和系统记录"
      }
    }
  },

  "naming": {
    "subproject": {
      "pattern": "^\\d{2}_.+_v\\d+\\.\\d+\\.\\d+$",
      "description": "{编号}_{主题}_v{MAJOR}.{MINOR}.{PATCH}",
      "rules": {
        "编号": "两位数字，脚本自动递增",
        "主题": "中文，3~10 字",
        "版本号": "三段式语义版本号，新建默认 1.0.0"
      }
    },
    "subfolder": {
      "specs": [
        { "prefix": "01", "title": "问题答疑", "stem": "01_问题答疑" },
        { "prefix": "02", "title": "课题研究", "stem": "02_课题研究" },
        { "prefix": "03", "title": "代码程序", "stem": "03_代码程序" }
      ],
      "pattern": "^(01_问题答疑|02_课题研究|03_代码程序)_v\\d+\\.\\d+\\.\\d+$",
      "versionRules": {
        "empty": "v0.0.0",
        "hasContent": "v1.0.0 起步",
        "01_问题答疑": "文件夹版本表示该分类下内容文件集合版本；新增/删除内容文件，或任一内容文件版本升级时，必须同步升级文件夹版本。",
        "02_课题研究": "文件夹版本表示该分类下内容文件集合版本；新增/删除内容文件，或任一内容文件版本升级时，必须同步升级文件夹版本。",
        "03_代码程序": "文件夹版本表示代码程序整体版本；源码、配置、构建产物作为整体随文件夹版本管理。"
      }
    },
    "contentFile": {
      "pattern": "^\\d{2}_.+_v\\d+\\.\\d+\\.\\d+\\.[^.]+$",
      "description": "01_问题答疑 与 02_课题研究 内的内容文件使用 {两位编号}_{标题}_v{MAJOR}.{MINOR}.{PATCH}.{扩展名}，文件版本与子项目版本互相独立。",
      "versionedSubfolders": ["01_问题答疑", "02_课题研究"],
      "folderVersionedSubfolders": ["03_代码程序"],
      "rules": {
        "01_问题答疑": "每个问答内容文件必须带独立版本号，新建默认 v1.0.0",
        "02_课题研究": "每个研究内容文件必须带独立版本号，新建默认 v1.0.0",
        "03_代码程序": "代码程序作为一个整体由 03_代码程序_v{x.y.z} 文件夹版本管理，内部文件不强制带文件级版本号，可保留工具链原生命名"
      },
      "excludeFromNumbering": ["03_代码程序"],
      "excludeFromFileVersioning": ["03_代码程序"]
    },
    "fixedFiles": {
      "description": "子项目固定文件，不带编号",
      "names": ["目录.md", "版本记录.md"]
    },
    "conversationRecord": {
      "pattern": "^\\d{2}_.+_v\\d+\\.\\d+\\.\\d+\\.md$",
      "description": "{子项目文件夹名}.md"
    },
    "knowledgeDistill": {
      "pattern": "^[^_v].+\\.md$",
      "description": "{话题名}.md — 稳定文件名，不带 _v*"
    },
    "systemRecord": {
      "fixedNames": [
        "规则变更记录.md",
        "技能变更记录.md",
        "脚本治理记录.md",
        "教训库.md",
        "索引.md"
      ],
      "legacyFile": "rules-skills.md",
      "legacyAction": "migrate-then-archive"
    },
    "historySnapshot": {
      "output": "{子项目文件夹名}_{yyyyMMddHHmmss}",
      "agentsSkills": "{Skill名}_{yyyyMMddHHmmss}",
      "agentsRules": "{rule文件名}_{yyyyMMddHHmmss}.md",
      "systemFolder": "{.system子文件夹名}_{yyyyMMddHHmmss}",
      "memoryKnowledge": "{话题名}_v{x.y.z}.md",
      "memoryMap": "全局知识地图_v{x.y.z}.md"
    }
  },

  "bomCheck": {
    "description": "必须保持 UTF-8 with BOM 的 .ps1 文件",
    "files": [
      ".agents/skills/版本控制备份/scripts/backup.ps1",
      ".agents/skills/子项目管理/scripts/new_project.ps1",
      ".agents/skills/子项目管理/scripts/next_number.ps1",
      ".agents/skills/子项目管理/scripts/normalize_project.ps1",
      ".agents/skills/框架体检/scripts/framework-check.ps1",
      ".agents/skills/项目规范化/scripts/normalize.ps1",
      ".agents/skills/记忆管理/scripts/remove.ps1"
    ]
  },

  "memoryCleanRules": {
    "description": ".memory 当前区洁净度规则",
    "forbiddenPatterns": [
      { "path": ".memory/知识提炼/", "pattern": "_v\\d+\\.\\d+\\.\\d+\\.[^.]+$", "reason": "历史副本应在 .history/.memory/知识提炼/" },
      { "path": ".memory/", "pattern": "全局知识地图_v", "reason": "历史副本应在 .history/.memory/全局知识地图/" }
    ],
    "allowedDirs": ["对话记录", "系统记录", "知识提炼"],
    "rootFiles": ["全局知识地图.md"]
  }
}
